<UserControl x:Class="ProtoLink.Windows.Messanger.Views.AddContactView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:ProtoLink.Windows.Messanger.Views"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Close button only shown when not embedded in settings -->
        <Button Command="{Binding CloseCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="30" Height="30"
                Content="✕"
                Background="Transparent"
                BorderThickness="0"
                FontSize="18"
                ToolTip="Close Add Contact"
                Visibility="{Binding IsEmbedded, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Stretch" Margin="0,0,0,0">
                <!-- Title only shown when not embedded in settings -->
                <TextBlock Text="Add Contact" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"
                          Visibility="{Binding IsEmbedded, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>

                <TextBlock Text="User ID" Margin="0,0,0,5"/>
                <TextBox Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"
                         Height="30"
                         VerticalContentAlignment="Center"/>

                <Button Content="Add Contact"
                        Command="{Binding AddContactCommand}"
                        Height="30"
                        Margin="0,0,0,20"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusMessage, Converter={StaticResource StatusColorConverter}}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <TextBlock Text="Instructions:" FontWeight="Bold" Margin="0,20,0,10"/>
                <TextBlock Text="Enter the User ID (GUID) of the person you want to add as a contact. You can find user IDs in the system or get them from other users."
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>